{
  "id": "yixiaoer-skill",
  "name": "蚁小二多平台发布",
  "version": "1.1.0",
  "description": "蚁小二自媒体多平台发布插件。集成40+主流平台内容一键发布、账号管理、数据监控。支持视频、图文、文章三种内容类型的批量同步发布。【v1.1.0优化】增加videoKey/coverKey参数支持，避免重复上传；增加封面自动提取功能。",
  "main": "dist/index.js",
  "entry": "dist/index.js",
  "author": "yixiaoer",
  "license": "MIT",
  "homepage": "https://www.yixiaoer.cn",
  "repository": {
    "type": "git",
    "url": "https://github.com/yixiaoer888/yixiaoer-skill"
  },
  "keywords": [
    "yixiaoer",
    "yixiaoer-skill",
    "openclaw",
    "openclaw-skill",
    "自媒体",
    "内容分发",
    "多平台发布",
    "抖音",
    "小红书",
    "视频号",
    "B站",
    "微博",
    "快手",
    "一键分发",
    "批量发布"
  ],
  "categories": [
    "Social Media",
    "Content Distribution",
    "Automation"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["apiKey"],
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "蚁小二 API Key（必填，从蚁小二后台获取）"
      },
      "platformAccounts": {
        "type": "object",
        "description": "平台账号映射（可选，用于自动匹配账号）",
        "additionalProperties": {
          "type": "string"
        }
      }
    }
  },
  "capabilities": {
    "platforms": {
      "video": 28,
      "imageText": 9,
      "article": 20,
      "total": 40
    },
    "features": [
      "unified-entry",
      "multi_platform_publish",
      "batch_publish",
      "scheduled-publish",
      "draft-save",
      "account-management",
      "content-monitoring",
      "auto-account-discovery",
      "form-validation",
      "vip-check",
      "videoKey-support",
      "coverKey-support",
      "auto-extract-cover"
    ],
    "optimizations": [
      {
        "version": "1.1.0",
        "changes": [
          "增加 videoKey 参数，支持直接使用已上传的 OSS 视频 key",
          "增加 coverKey 参数，支持直接使用已上传的 OSS 封面 key",
          "增加 autoExtractCover 选项，未提供封面时自动从视频提取",
          "使用 esbuild 打包所有模块，防止 AI 直接 import 内部方法"
        ]
      }
    ]
  },
  "tools": [
    {
      "name": "publish_video",
      "category": "publish",
      "description": "发布视频到指定平台。支持抖音、快手、小红书、视频号、B站等28+平台。【优化】支持 videoKey/coverKey 参数直接使用已上传资源，未提供封面时自动从视频提取。"
    },
    {
      "name": "publish_image_text",
      "category": "publish",
      "description": "发布图文内容到指定平台。支持抖音、快手、小红书、视频号、微博等9个平台。"
    },
    {
      "name": "publish_article",
      "category": "publish",
      "description": "发布文章到指定平台。支持微信公众号、百家号、头条号、知乎、微博等20+平台。"
    },
    {
      "name": "multi_platform_publish",
      "category": "publish",
      "description": "一键发布到多个平台。"
    },
    {
      "name": "batch_publish",
      "category": "publish",
      "description": "批量发布内容到多个平台。"
    },
    {
      "name": "list_accounts",
      "category": "account",
      "description": "获取账号列表。"
    },
    {
      "name": "account_overviews",
      "category": "account",
      "description": "获取账号数据概览。"
    },
    {
      "name": "content_overviews",
      "category": "data",
      "description": "查询已发布作品的数据。"
    },
    {
      "name": "get_publish_preset",
      "category": "helper",
      "description": "获取平台发布预设。"
    },
    {
      "name": "validate_form",
      "category": "helper",
      "description": "验证发布表单。"
    }
  ]
}
