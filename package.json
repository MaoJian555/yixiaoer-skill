{
  "name": "@yixiaoermail/openclaw-yixiaoer",
  "version": "1.3.1",
  "description": "蚁小二多平台内容发布 OpenClaw 插件 - 支持抖音、小红书、B站、快手、视频号等40+平台一键发布",
  "openclaw": {
    "type": "plugin",
    "id": "openclaw-yixiaoer",
    "install": {
      "minHostVersion": ">=2026.3.13"
    },
    "extensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:bundle": "node scripts/bundle-skill.mjs",
    "build:all": "npm run build && npm run build:bundle",
    "build:pkg": "powershell -File scripts/build-package.ps1",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:bundle": "node dist/bundle/index.js",
    "test": "jest",
    "verify": "npx tsc --noEmit && npm test -- --runInBand",
    "generate-docs": "node scripts/generate-platform-docs.mjs",
    "generate-rules": "node scripts/generate-platform-rules.mjs",
    "generate-form-schema": "node scripts/generate-platform-form-schema.mjs",
    "sync": "node scripts/generate-platform-docs.mjs && node scripts/generate-platform-rules.mjs && node scripts/generate-platform-form-schema.mjs && npm run build",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "yixiaoer",
    "openclaw",
    "openclaw-plugin",
    "openclaw-yixiaoer",
    "publisher",
    "social-media",
    "multi-platform",
    "xiaohongshu",
    "douyin",
    "bilibili",
    "kuaishou",
    "wechat",
    "toutiao",
    "zhihu",
    "weibo",
    "baijiahao",
    "shipinghao",
    "content-distribution",
    "auto-publish"
  ],
  "author": "yixiaoer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yixiaoer888/yixiaoer-skill.git"
  },
  "bugs": {
    "url": "https://github.com/yixiaoer888/yixiaoer-skill/issues"
  },
  "homepage": "https://www.yixiaoer.cn",
  "dependencies": {
    "axios": "^1.6.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.31.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "package.json",
    "llms.txt"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.13"
  }
}
