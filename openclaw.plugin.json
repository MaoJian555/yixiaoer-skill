{
  "name": "yixiaoer-skill",
  "version": "1.0.3",
  "description": "蚁小二自媒体多平台发布插件。集成多平台内容一键发布、作品数据监控及账号状态管理。支持 40+ 主流媒体平台（抖音、小红书、视频号等）的文章、图文、视频一键同步发布。更多接口定义请参考：https://s.apifox.cn/e66df935-0c39-44d0-8096-abd39417fa6a/llms.txt",
  "entry": "dist/index.js",
  "author": "yixiaoer",
  "license": "MIT",
  "homepage": "https://www.yixiaoer.cn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaoJian555/yixiaoer-skill.git"
  },
  "keywords": [
    "yixiaoer",
    "yixiaoer-skill",
    "openclaw",
    "clawhub",
    "自媒体",
    "内容分发",
    "抖音",
    "小红书",
    "视频号",
    "B站",
    "微博",
    "多平台发布",
    "蚁小二",
    "一键分发"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["apiKey"],
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "蚁小二 API Key（必填，用于身份验证）"
      }
    }
  },
  "skills": [
    {
      "action": "list-accounts",
      "description": "【发布前导】查询绑定的已登录账号。获取 platformAccountId。关键词：获取账号、选账号、绑定情况。",
      "parameters": [
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1,
          "description": "页码"
        },
        {
          "name": "size",
          "type": "number",
          "required": false,
          "default": 20,
          "description": "每页数量"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "get-publish-preset",
      "description": "【高级配置】获取指定账号的发布预设（分类、话题等）。在调用发布接口前必看。关键词：查分类、查话题、查看发布要求。",
      "parameters": [
        {
          "name": "platformAccountId",
          "type": "string",
          "required": true,
          "description": "媒体账号ID"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "publish-video",
      "description": "【视频分发】发布视频。支持 40+ 平台。建议先调用 get-publish-preset 获取平台分类和话题。关键词：一键发布视频、发抖音、发布短视频。",
      "parameters": [
        {
          "name": "platformAccountId",
          "type": "string",
          "required": true,
          "description": "媒体账号ID"
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "视频标题"
        },
        {
          "name": "description",
          "type": "string",
          "required": true,
          "description": "视频描述"
        },
        {
          "name": "videoPath",
          "type": "string",
          "required": true,
          "description": "视频 URL 或绝对路径"
        },
        {
          "name": "coverPath",
          "type": "string",
          "required": true,
          "description": "视频封面 URL 或路径"
        },
        {
          "name": "contentPublishForm",
          "type": "object",
          "required": false,
          "description": "平台特有表单数据（如 category, tags, declaration 等）。参考 get-publish-preset 的返回结果。"
        },
        {
          "name": "publishChannel",
          "type": "string",
          "required": false,
          "enum": ["local", "cloud"],
          "default": "cloud",
          "description": "发布渠道"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "publish-image-text",
      "description": "【图文分发】发布图文动态、小红书笔记等。关键词：发图文、发笔记、发动态。",
      "parameters": [
        {
          "name": "platformAccountId",
          "type": "string",
          "required": true,
          "description": "媒体账号ID"
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "图文标题"
        },
        {
          "name": "description",
          "type": "string",
          "required": true,
          "description": "图文正文"
        },
        {
          "name": "imagePaths",
          "type": "array",
          "required": true,
          "items": { "type": "string" },
          "description": "图片路径列表"
        },
        {
          "name": "contentPublishForm",
          "type": "object",
          "required": false,
          "description": "平台特有表单数据。"
        },
        {
          "name": "publishChannel",
          "type": "string",
          "required": false,
          "enum": ["local", "cloud"],
          "default": "cloud",
          "description": "发布渠道"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "publish-article",
      "description": "【文章分发】发布长文、公众号内容。关键词：发文章、同步公众号、发布说明。",
      "parameters": [
        {
          "name": "platformAccountId",
          "type": "string",
          "required": true,
          "description": "媒体账号ID"
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "文章标题"
        },
        {
          "name": "description",
          "type": "string",
          "required": true,
          "description": "HTML 格式的正文内容"
        },
        {
          "name": "coverPath",
          "type": "string",
          "required": false,
          "description": "素材封面路径"
        },
        {
          "name": "contentPublishForm",
          "type": "object",
          "required": false,
          "description": "平台特有表单数据。"
        },
        {
          "name": "publishChannel",
          "type": "string",
          "required": false,
          "enum": ["local", "cloud"],
          "default": "cloud",
          "description": "发布渠道"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "account-overviews",
      "description": "【数据查询】获取账号概览（粉丝数等）。关键词：查粉丝、查账号表现。",
      "parameters": [
        {
          "name": "platform",
          "type": "string",
          "required": true,
          "description": "平台中文名，如：抖音"
        },
        {
          "name": "name",
          "type": "string",
          "required": false,
          "description": "模糊搜索账号名"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "get-publish-records",
      "description": "【任务追踪】获取发布进度和历史记录。关键词：查进度、看记录、查历史。",
      "parameters": [
        {
          "name": "page",
          "type": "number",
          "required": false,
          "default": 1
        },
        {
          "name": "size",
          "type": "number",
          "required": false,
          "default": 20
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "upload-url",
      "description": "【素材预处理】获取素材上传地址。关键词：上传素材、上传视频、上传图片。",
      "parameters": [
        {
          "name": "fileName",
          "type": "string",
          "required": true,
          "description": "文件名（带后缀）"
        },
        {
          "name": "fileSize",
          "type": "number",
          "required": true,
          "description": "文件大小（Byte）"
        },
        {
          "name": "contentType",
          "type": "string",
          "required": true,
          "description": "MIME 类型，如 video/mp4"
        }
      ],
      "permissions": ["network"]
    },
    {
      "action": "get-extended-api-docs",
      "description": "【文档扩展】获取蚁小二 4.0 的完整 API 文档，包含用户管理、设备管理、任务集管理等非发布核心接口。当 AI 需要执行本插件列表以外的操作时，应首先参考此文档进行学习或调用提示（Hint）。",
      "parameters": [],
      "permissions": ["network"]
    }
  ]
}
